# ============================================================
# 인프라 데이터 조회 에이전트 — 환경변수 설정
# ============================================================
# 이 파일을 .env로 복사하여 실제 값으로 수정하세요.
#   cp .env.example .env
#
# pydantic-settings 규칙:
#   - list[str] 필드는 반드시 JSON 배열 형식 (예: ["a","b"])
#   - bool 필드는 true / false (소문자)
# ============================================================

# === LLM 설정 ===
# provider: ollama | fabrix | gemini
LLM_PROVIDER=ollama
# 오픈소스 LLM 모델명 (예: llama3.1:8b, llama3.1:70b, gemma2:9b, gemma3:12b, qwen2.5:14b, mistral:7b)
LLM_MODEL=llama3.1:8b
# Ollama 서버 주소
LLM_OLLAMA_BASE_URL=http://localhost:11434
# Ollama 요청 타임아웃 (초) — 모델/프롬프트 복잡도에 따라 조정
LLM_OLLAMA_TIMEOUT=180
# Ollama Gateway API 키 → .encenv에서 관리 (LLM_API_KEY)

# Gemini 설정 (LLM_PROVIDER=gemini 시)
# API 키는 .encenv 파일에서 관리 (LLM_GEMINI_API_KEY)
# Gemini 모델명 (비어있으면 LLM_MODEL 사용)
# 권장: gemini-2.0-flash (안정), gemini-3.1-pro (최신)
LLM_GEMINI_MODEL=gemini-2.0-flash

# FabriX 설정 (LLM_PROVIDER=fabrix 시)
FABRIX_BASE_URL=
# FabriX API 키 / 클라이언트 키 → .encenv에서 관리 (FABRIX_API_KEY, FABRIX_CLIENT_KEY)
# FabriX 모델명 (비어있으면 LLM_MODEL 사용)
FABRIX_CHAT_MODEL=

# === DB 연결 ===
# db_backend: dbhub (MCP 서버 경유) | direct (PostgreSQL 직접 연결)
DB_BACKEND=direct
# direct 모드 시 PostgreSQL 연결 문자열
DB_CONNECTION_STRING=postgresql://infra_user:password@localhost:5433/infra_db

# === MCP 서버 (DBHub) 설정 (DB_BACKEND=dbhub 시) ===
DBHUB_SERVER_URL=http://localhost:9090/sse
# ※ 반드시 mcp_server/config.toml의 [[sources]] name 값과 정확히 일치해야 함
# ※ 불일치 시 "알 수 없는 소스" 에러 발생
DBHUB_SOURCE_NAME=infra_db
# MCP 호출 전체 대기시간 (초)
DBHUB_MCP_CALL_TIMEOUT=60

# === 클라이언트 쿼리 정책 ===
# SQL 생성 실패 시 최대 재시도 횟수
QUERY_MAX_RETRY_COUNT=3
# SQL 생성 시 기본 LIMIT 절 값
QUERY_DEFAULT_LIMIT=1000
# 데이터 충분성 검사: hint/synonym 매핑의 최소 매칭 비율 (0.0~1.0)
QUERY_SUFFICIENCY_REQUIRED_THRESHOLD=0.7
# 데이터 충분성 검사: LLM 추론 매핑의 최소 매칭 비율 (0.0~1.0)
QUERY_SUFFICIENCY_OPTIONAL_THRESHOLD=0.5

# === 보안 ===
# 마스킹 대상 컬럼명 목록 (JSON 배열 형식 필수)
SECURITY_SENSITIVE_COLUMNS=["password","secret","token","api_key","private_key","credential"]
# 마스킹 치환 문자열
SECURITY_MASK_PATTERN=***MASKED***
# 부분 마스킹 대상 컬럼 (JSON 배열 형식, 예: ["email","phone"])
SECURITY_PARTIAL_MASK_COLUMNS=[]
# IP 주소 마스킹 여부
SECURITY_MASK_IP=false
# 이메일 주소 마스킹 여부
SECURITY_MASK_EMAIL=false

# === API 서버 ===
API_HOST=0.0.0.0
API_PORT=8000
# CORS 허용 오리진 (JSON 배열 형식, 운영: ["https://your-domain.com"])
API_CORS_ORIGINS=["*"]
# 일반 질의 타임아웃 (초) — 그래프 전체 실행 제한
API_QUERY_TIMEOUT=60
# 파일 업로드 질의 타임아웃 (초) — 엑셀/Word 템플릿 처리 시 LLM 호출이 많으므로 넉넉히
API_FILE_QUERY_TIMEOUT=120

# === 운영자 인증 ===
ADMIN_USERNAME=admin
# 운영자 비밀번호 / JWT 시크릿 → .encenv에서 관리 (ADMIN_PASSWORD, ADMIN_JWT_SECRET)
# JWT 토큰 만료 시간 (시간)
ADMIN_JWT_EXPIRE_HOURS=24

# === 체크포인트 (대화 상태 저장) ===
# checkpoint_backend: sqlite | postgres
CHECKPOINT_BACKEND=sqlite
# SQLite 파일 경로 또는 :memory:
CHECKPOINT_DB_URL=checkpoints.db

# === 로그 ===
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Redis 비밀번호 → .encenv에서 관리 (REDIS_PASSWORD)
# TLS/SSL 사용 여부
REDIS_SSL=false
# Redis 소켓 타임아웃 (초)
REDIS_SOCKET_TIMEOUT=5

# === 스키마 캐시 ===
# 캐시 백엔드: redis | file
SCHEMA_CACHE_BACKEND=redis
# 파일 캐시 디렉토리 (SCHEMA_CACHE_BACKEND=file 시)
SCHEMA_CACHE_CACHE_DIR=.cache/schema
# 스키마 캐시 활성화 여부
SCHEMA_CACHE_ENABLED=true
# 컬럼 설명 자동 생성 여부 (LLM 사용)
SCHEMA_CACHE_AUTO_GENERATE_DESCRIPTIONS=true

# === 시멘틱 라우팅 (멀티 DB) ===
# true: 멀티 DB 시멘틱 라우팅 활성화 (ACTIVE_DB_IDS가 있으면 자동 활성화)
ENABLE_SEMANTIC_ROUTING=false
# 활성 DB ID 목록 (쉼표 구분, MCP 서버에 등록된 소스명과 일치해야 함)
# ACTIVE_DB_IDS=polestar,cloud_portal,itsm,itam

# === Polestar 전용 프롬프트 ===
# Polestar EAV 구조 전용 시스템 프롬프트를 적용할 DB ID
# ACTIVE_DB_IDS에 포함된 DB 중 하나를 지정 (예: polestar, polestar_pg)
# 비어있으면 모든 DB에 범용 프롬프트 적용
POLESTAR_DB_ID=polestar

# === 멀티턴 대화 / Human-in-the-loop ===
# SQL 실행 전 사용자 승인 요구 여부
ENABLE_SQL_APPROVAL=false
# 대화 세션 최대 턴 수
CONVERSATION_MAX_TURNS=20
# 대화 세션 유효 시간 (시간)
CONVERSATION_TTL_HOURS=24

# NOTE: DB 연결 문자열은 MCP 서버 VM에서 관리합니다.
# MCP 서버 설정: mcp_server/config.toml + mcp_server/.env
