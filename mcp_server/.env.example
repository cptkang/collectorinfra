# === 개발환경 기본값 (Docker 컨테이너 접속) ===

# PostgreSQL (Docker, port 5433)
INFRA_DB_CONNECTION=postgresql://infra_user:infra_pass_2024@localhost:5433/infra_db

# DB2 (Docker, port 50000)
# ibm_db 연결 문자열 형식
INFRA_DB2_CONNECTION=DATABASE=infradb;HOSTNAME=localhost;PORT=50000;PROTOCOL=TCPIP;UID=db2inst1;PWD=db2pass2024;

