# ============================================================
# MCP 서버 (DBHub) — 환경변수 설정
# ============================================================
# config.toml과 함께 사용된다.
#   - config.toml: 서버 기본 설정 + 데이터소스 정의 (readonly, query_timeout, max_rows, pool 설정)
#   - .env: 서버 설정 오버라이드 + DB 연결 문자열 (보안상 TOML에 기재하지 않음)
#
# 환경변수 오버라이드 규칙:
#   - SERVER_* → config.toml의 [server] 섹션 오버라이드
#   - {SOURCE_NAME_UPPER}_CONNECTION → config.toml [[sources]]의 connection 오버라이드
#     소스명을 대문자로 변환한 것이 환경변수 접두사 (예: infra_db → INFRA_DB_CONNECTION)
#   - 이미 시스템 환경변수로 설정된 값은 .env보다 우선
#
# 소스별 세부 설정(readonly, query_timeout, max_rows, pool_min_size, pool_max_size)은
# config.toml에서만 변경 가능하다.
# ============================================================

# === MCP 서버 설정 ===
# 서버 이름 (FastMCP 인스턴스 식별용, 클라이언트 로그에 표시)
SERVER_NAME=dbhub-server
# 바인딩 호스트 (0.0.0.0: 모든 인터페이스 | 127.0.0.1: 로컬만)
SERVER_HOST=0.0.0.0
# 서버 포트 (메인 앱의 DBHUB_SERVER_URL 포트와 일치해야 함)
SERVER_PORT=9099
# 네트워크 전송 방식 (sse: Server-Sent Events — 별도 VM/컨테이너 간 통신 시 필수)
SERVER_TRANSPORT=sse
# 로그 레벨 (debug | info | warning | error)
SERVER_LOG_LEVEL=info

# === 데이터소스 연결 문자열 ===
# config.toml의 [[sources]] name에 대응하는 환경변수로 DB 연결 정보를 설정한다.
# 연결 문자열이 비어있거나 주석 처리된 소스는 자동으로 비활성 처리된다.
#
# 환경변수명 규칙: {config.toml의 name을 대문자로}_CONNECTION
#   config.toml name="infra_db"      → INFRA_DB_CONNECTION
#   config.toml name="infra_db2"     → INFRA_DB2_CONNECTION
#   config.toml name="polestar"      → POLESTAR_CONNECTION
#   config.toml name="cloud_portal"  → CLOUD_PORTAL_CONNECTION
#
# ※ 클라이언트(루트 .env)의 DBHUB_SOURCE_NAME / ACTIVE_DB_IDS 값도
#    config.toml의 name과 정확히 일치해야 한다.

# --- 개발환경 기본값 (Docker 컨테이너 접속) ---

# PostgreSQL (Docker, port 5433) — config.toml name="infra_db"
# 형식: postgresql://user:password@host:port/dbname
INFRA_DB_CONNECTION=postgresql://infra_user:password@localhost:5433/infra_db

# DB2 (Docker, port 50000) — config.toml name="infra_db2"
# ibm_db 연결 문자열 형식 (세미콜론 구분, 키=값 쌍)
INFRA_DB2_CONNECTION=DATABASE=infradb;HOSTNAME=localhost;PORT=50000;PROTOCOL=TCPIP;UID=db2inst1;PWD=db2pass2024;

# Polestar PostgreSQL (Docker, port 5434) — config.toml name="polestar"
# DB2 대신 macOS 호환 PostgreSQL로 Polestar 테스트 환경 구동 시 사용
# POLESTAR_CONNECTION=postgresql://polestar_user:password@localhost:5434/infradb

# --- 운영환경 (멀티 DB, 필요 시 활성화) ---
# config.toml에 [[sources]] 정의가 있어야 연결 문자열이 적용된다.
# POLESTAR_CONNECTION=postgresql://user:pass@host:5432/polestar_db
# CLOUD_PORTAL_CONNECTION=postgresql://user:pass@host:5432/cloud_portal_db
# ITSM_CONNECTION=postgresql://user:pass@host:5432/itsm_db
# ITAM_CONNECTION=postgresql://user:pass@host:5432/itam_db
